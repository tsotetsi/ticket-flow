#!/bin/bash
# causes script to exit immediately if any command fails.
set -o errexit
# causes the script to fail if any command in a pipeline fails.
set -o pipefail
# exit if an unset(undefined) variable is referenced.
set -o nounset

# Add simple debug output messages.
echo "Current working directory: $(pwd)"
echo "Python version: $(python --version)"
# NB: You can use a while loop here
#     to wait for certain services
#     be available.

# Check for any django related issues.
echo "Checking django related issues..."
python manage.py check || {
  echo "Checking django related issues failed..."
  exit 1
}
# Database migrations with error checking
echo "Checking database migrations..."
python manage.py makemigrations || {
    echo "Migration preparation failed..."
    exit 1
}

echo "Applying database migrations..."
python manage.py migrate || {
    echo "Database migration failed..."
    exit 1
}
# Dockerized env or production needs this. Otherwise your
# static files will not show(404).
echo "Collecting static files..."
python manage.py collectstatic --noinput || {
    echo "Static files collection failed"
    exit 1
}

echo "Start Gunicorn..."
exec gunicorn config.wsgi:application --bind 0.0.0.0:8000 \
    --workers 3 \
    --log-level=info \
    --log-file=- \
    --capture-output